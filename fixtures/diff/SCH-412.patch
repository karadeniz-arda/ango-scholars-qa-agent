+import { useQuery } from '@tanstack/react-query';
+import { createUseQueryFetcher } from '@/api/core/fetcher';
+import { apiUrlPrefix } from '@/api/core/env';
+import type { paths } from '@/api/data/scholars-server';
+
+const useQueryFetcher = createUseQueryFetcher<paths, '/skills/export-csv', 'get'>(
+  '/skills/export-csv',
+  'get',
+  { apiUrlPrefix },
+);
+
+export function useExportSkillsTaxonomy(args = {}, options = {}) {
+  const [queryKey, fetch] = useQueryFetcher(args, useExportSkillsTaxonomy);
+  return useQuery({ queryKey, queryFn: fetch, enabled: false, ...options });
+}
+
